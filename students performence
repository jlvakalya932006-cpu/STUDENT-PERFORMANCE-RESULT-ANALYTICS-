def grade(x):
    if x >= 90:
        return 'A'
    elif x >= 80:
        return 'B'
    elif x >= 70:
        return 'C'
    elif x >= 60:
        return 'D'
    elif x >= 50:
        return 'E'
    else:
        return 'F'

df['Grade'] = df['Percentage'].apply(grade)

df['Result'] = np.where(df['Percentage'] >= 40, 'Pass', 'Fail')

